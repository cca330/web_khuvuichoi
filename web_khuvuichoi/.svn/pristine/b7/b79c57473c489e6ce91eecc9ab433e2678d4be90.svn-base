#overlay.active {
  opacity: 1;
  pointer-events: auto;
} */

.sidebar {
  width: 220px;
  background: #2c3e50;
  color: #fff;
}

.sidebar h2 {
  padding: 20px;
  text-align: center;
  border-bottom: 1px solid rgba(255,255,255,0.2);
}

.sidebar a {
  display: block;
  padding: 12px 20px;
  color: #ddd;
  text-decoration: none;
  transition: 0.3s;
}

.sidebar a:hover,
.sidebar a.active {
  background: #7a6628;
  color: #fff;
}

/* DETAIL CONTENT */
.detail-header, .detail-body, .detail-thongso, .detail-footer {
  padding: 20px;
  border-bottom: 1px solid #e6e9ee;
}
.detail-header h2 {
  font-size: 22px;
  font-weight: 600;
}
.detail-body h3 {
  font-size: 20px;
  font-weight: 600;
}
.detail-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 12px 0;
}
.detail-row i {
  font-size: 22px;
  color: #374151;
}
.detail-row p {
  font-size: 15px;
  color: #1f2937;
}

/* STAT & FOOTER */
.detail-thongso {
  display: flex;
  justify-content: space-between;
  text-align: center;
  background: #eaecf1;
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-item i {
  font-size: 28px;
  color: #2563eb;
  margin-bottom: 6px;
}
.detail-footer {
  display: flex;
  justify-content: center;
  gap: 20px;
}
.detail-footer .btnsecondary {
  background: #2563eb;
  color: #fff;
  border: none;
  border-radius: 10px;
  padding: 10px 20px;
  cursor: pointer;
}
.detail-footer .btnremove {
  background: #ff4141;
  color: #fff;
  border: none;
  border-radius: 10px;
  padding: 10px 20px;
  cursor: pointer;
}
