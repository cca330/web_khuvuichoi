* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* LAYOUT CHUNG */
.layout {
  display: flex;
  min-height: 100vh;
  background: #f5f6fa;
}

/* SIDEBAR MENU TRÁI */
.sidebar-menu {
  width: 220px;
  background: #2c3e50;
  color: #fff;
  padding: 20px;
  flex-shrink: 0;
}

.sidebar-menu .logo {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 20px;
}

.sidebar-menu .menu {
  list-style: none;
}

.sidebar-menu .menu li {
  margin-bottom: 12px;
}

.sidebar-menu .menu li a {
  color: #fff;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  padding: 6px 10px;
  border-radius: 6px;
  transition: background 0.2s;
}

.sidebar-menu .menu li a:hover {
  background: rgba(255,255,255,0.1);
}

.sidebar-menu .menu li a.logout {
  background: #eb2525;
}

/* MAIN CONTENT */
.content {
  flex: 1;
  padding: 20px 40px;
}

/* HEADER */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}
h1 {
  font-size: 28px;
  font-weight: 700;
}
.muted {
  color: #6b7280;
  margin-top: 4px;
}
.top-buttons {
  display: flex;
  gap: 8px;
}
.btn {
  padding: 10px 14px;
  border-radius: 8px;
  border: 1px solid #e6e9ee;
  background: #fff;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}
.btn.primary {
  background: #2563eb;
  color: #fff;
  border-color: transparent;
}
.btn.logout {
  background: #eb2525;
  color: #fff;
  border-color: transparent;
}

/* SEARCH & FILTERS */
.search-box {
  margin-top: 10px;
  width: 360px;
  display: flex;
  align-items: center;
  background: #fff;
  padding: 10px 14px;
  border-radius: 10px;
  border: 1px solid #e6e9ee;
}
.search-box i {
  font-size: 18px;
  color: #9ca3af;
  margin-right: 8px;
}
.search-box input {
  border: 0;
  outline: 0;
  width: 100%;
  font-size: 14px;
}
.filters {
  display: flex;
  gap: 10px;
  margin: 18px 0;
  flex-wrap: wrap;
}
.filter-btn {
  padding: 8px 14px;
  border-radius: 20px;
  background: #fff;
  border: 1px solid #e6e9ee;
  cursor: pointer;
  font-size: 13px;
}

/* TABLE */
.table-wrap {
  background: #fff;
  border-radius: 10px;
  overflow: hidden;
  border: 1px solid #eef2f6;
  margin: 20px 0;
}
table {
  width: 100%;
  border-collapse: collapse;
}
thead {
  background: #fbfdff;
}
th,
td {
  padding: 14px;
  text-align: left;
  font-size: 14px;
  border-bottom: 1px solid #f3f4f6;
}

/* PAGINATION */
.pagination {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 18px;
  margin-bottom: 30px;
}
.page-rows {
  display: flex;
  align-items: center;
  gap: 10px;
}
.page-controls {
  display: flex;
  gap: 8px;
}
.page-btn {
  padding: 8px 12px;
  border-radius: 8px;
  border: 1px solid #e6e9ee;
  background: #fff;
  cursor: pointer;
}
.page-btn.active {
  background: #2563eb;
  color: #fff;
  border-color: #2563eb;
}

/* OVERLAY & SIDEBAR CHI TIẾT */
