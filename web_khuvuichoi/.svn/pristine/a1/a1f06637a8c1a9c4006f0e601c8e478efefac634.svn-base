<h2>Chi tiết trò chơi</h2>

<div class="card">
    <h3><?= $game['name'] ?></h3>
    <p><?= $game['description'] ?></p>
    <p>Giá vé: <b><?= number_format($game['price']) ?> đ</b></p>
    <p>Độ tuổi: <?= $game['recommended_age'] ?>+</p>
    <p>Trạng thái: <?= $game['status'] ?></p>
</div>

<h3>Thống kê</h3>
<div class="stats">
    <div class="stat-card">🎟 Tổng vé: <?= $stats['total_tickets'] ?></div>
    <div class="stat-card">✅ Vé đã dùng: <?= $stats['used_tickets'] ?></div>
    <div class="stat-card">💰 Doanh thu: <?= number_format($stats['revenue']) ?> đ</div>
</div>

<a href="javascript:history.back()" class="btn">← Quay lại</a>

